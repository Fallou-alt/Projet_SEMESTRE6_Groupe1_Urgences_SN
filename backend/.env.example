# ─────────────────────────────────────────────────────────────
# URGENCES SN — Configuration de l'environnement
# Copier ce fichier en .env et remplir les valeurs manquantes
# cp .env.example .env && php artisan key:generate
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME="Urgences SN"
APP_ENV=local          # local | production
APP_KEY=               # généré par php artisan key:generate
APP_DEBUG=true         # false en production obligatoirement
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ── Base de données (MySQL) ────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=urgences_sn   # créer la base avant de migrer
DB_USERNAME=root
DB_PASSWORD=              # mot de passe MySQL local

# ── Sessions ──────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Cache ─────────────────────────────────────────────────────
CACHE_STORE=file

# ── File d'attente ────────────────────────────────────────────
QUEUE_CONNECTION=sync

# ── Logs ──────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug        # debug | info | warning | error

# ── Mail (optionnel, non utilisé dans la v1) ──────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="contact@urgences-sn.sn"
MAIL_FROM_NAME="Urgences SN"

# ── Frontend ──────────────────────────────────────────────────
# URL de l'API à configurer aussi dans frontend/pages/api.js
FRONTEND_URL=http://localhost:5173

# ── Notes de déploiement ──────────────────────────────────────
# En production :
#   - APP_DEBUG=false
#   - APP_ENV=production
#   - Configurer un vrai serveur MySQL
#   - php artisan config:cache
#   - php artisan route:cache
